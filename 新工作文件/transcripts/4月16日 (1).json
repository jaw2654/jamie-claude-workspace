7, 14065, 95, 5322, 248, 23516, 22217, 101, 1546, 31742, 51770], "temperature": 0.0, "avg_logprob": -0.19462267557779947, "compression_ratio": 1.2640449438202248, "no_speech_prob": 0.2746446430683136}, {"id": 96, "seek": 20250, "start": 230.6, "end": 232.4, "text": "蠻特別的", "tokens": [51770, 164, 254, 119, 38446, 1546, 51860], "temperature": 0.0, "avg_logprob": -0.19462267557779947, "compression_ratio": 1.2640449438202248, "no_speech_prob": 0.2746446430683136}, {"id": 97, "seek": 23240, "start": 232.4, "end": 234.4, "text": "但是我覺得最特別還是人的互動", "tokens": [50365, 11189, 17689, 8661, 38446, 25583, 4035, 1546, 1369, 240, 12572, 50465], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 98, "seek": 23240, "start": 234.4, "end": 236.20000000000002, "text": "就是人的表演", "tokens": [50465, 5620, 4035, 1546, 17571, 31382, 50555], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 99, "seek": 23240, "start": 236.20000000000002, "end": 237.8, "text": "人的表演有非常多種", "tokens": [50555, 4035, 1546, 17571, 31382, 2412, 14392, 6392, 16516, 50635], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 100, "seek": 23240, "start": 237.8, "end": 240.70000000000002, "text": "所以你可以很細微的觀察到", "tokens": [50635, 7239, 42766, 4563, 41588, 39152, 1546, 25179, 47550, 4511, 50780], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 101, "seek": 23240, "start": 240.70000000000002, "end": 242.34, "text": "那你們現在聽到的聲音", "tokens": [50780, 4184, 19891, 12648, 21524, 4511, 1546, 29454, 18034, 50862], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 102, "seek": 23240, "start": 242.34, "end": 244.44, "text": "應該就是那些人在", "tokens": [50862, 26087, 5620, 4184, 13824, 4035, 3581, 50967], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 103, "seek": 23240, "start": 244.44, "end": 246.44, "text": "就是唱歌的聲音", "tokens": [50967, 5620, 39861, 29582, 1546, 29454, 18034, 51067], "temperature": 0.0, "avg_logprob": -0.22083302398226154, "compression_ratio": 1.2857142857142858, "no_speech_prob": 0.15367333590984344}, {"id": 104, "seek": 26240, "start": 262.4, "end": 264.4, "text": "好久沒有來漢南洞了", "tokens": [50365, 2131, 25320, 6963, 3763, 14065, 95, 31021, 12136, 252, 2289, 50465], "temperature": 0.0, "avg_logprob": -0.29646636699808054, "compression_ratio": 1.1393034825870647, "no_speech_prob": 0.2996434271335602}, {"id": 105, "seek": 26240, "start": 264.4, "end": 266.4, "text": "然後我就發現最近有一些新出的店", "tokens": [50465, 10213, 22020, 38927, 46777, 32241, 13824, 12560, 7781, 1546, 22469, 50565], "temperature": 0.0, "avg_logprob": -0.29646636699808054, "compression_ratio": 1.1393034825870647, "no_speech_prob": 0.2996434271335602}, {"id": 106, "seek": 26240, "start": 266.4, "end": 268.4, "text": "然後這個是Rose Jenny同款的衣服", "tokens": [50565, 10213, 41427, 49, 541, 20580, 13089, 48798, 1546, 9890, 96, 27408, 50665], "temperature": 0.0, "avg_logprob": -0.29646636699808054, "compression_ratio": 1.1393034825870647, "no_speech_prob": 0.2996434271335602}, {"id": 107, "seek": 26240, "start": 268.4, "end": 270.4, "text": "我有在小紅書上面看到的", "tokens": [50665, 39732, 3581, 7322, 33487, 29801, 49750, 18032, 1546, 50765], "temperature": 0.0, "avg_logprob": -0.29646636699808054, "compression_ratio": 1.1393034825870647, "no_speech_prob": 0.2996434271335602}, {"id": 108, "seek": 26240, "start": 280.4, "end": 282.4, "text": "是新的耶", "tokens": [51265, 1541, 12560, 1546, 22143, 51365], "temperature": 0.0, "avg_logprob": -0.29646636699808054, "compression_ratio": 1.139303482