id": 116, "seek": 29040, "start": 299.29999999999995, "end": 300.64, "text": "沒有穿過裙子", "tokens": [50810, 6963, 13740, 123, 8816, 8083, 247, 7626, 50877], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 117, "seek": 29040, "start": 302.32, "end": 303.58, "text": "這誰啊", "tokens": [50961, 2664, 20757, 4905, 51024], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 118, "seek": 29040, "start": 303.58, "end": 304.94, "text": "我覺得超適合你的", "tokens": [51024, 17689, 19869, 3330, 102, 14245, 18961, 51092], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 119, "seek": 29040, "start": 304.94, "end": 306.62, "text": "超適合我是嗎", "tokens": [51092, 19869, 3330, 102, 14245, 15914, 7434, 51176], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 120, "seek": 29040, "start": 308.56, "end": 309.56, "text": "好新穎喔", "tokens": [51273, 2131, 12560, 13740, 236, 10642, 51323], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 121, "seek": 29040, "start": 309.56, "end": 311.06, "text": "連我自己都覺得很新穎", "tokens": [51323, 36252, 1654, 17645, 7182, 11274, 4563, 12560, 13740, 236, 51398], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 122, "seek": 29040, "start": 311.06, "end": 312.65999999999997, "text": "美式", "tokens": [51398, 9175, 27584, 51478], "temperature": 0.0, "avg_logprob": -0.41535328456333703, "compression_ratio": 1.1851851851851851, "no_speech_prob": 0.3216353952884674}, {"id": 123, "seek": 29040, "start": 315.15999999999997, "end"